# Configuration Example
# Copy this to config.yaml and fill in your credentials

# API Keys - World Bank API requires NO API KEY! (Free and open)
# No API keys needed for data collection!

# AWS Configuration
aws:
  access_key_id: "YOUR_AWS_ACCESS_KEY"
  secret_access_key: "YOUR_AWS_SECRET_KEY"
  region: "us-east-1"
  s3_bucket: "your-presidential-analytics-bucket"
  s3_prefix: "presidential-data"

# Snowflake Configuration
snowflake:
  account: "your-account.region"
  user: "YOUR_USERNAME"
  password: "YOUR_PASSWORD"
  warehouse: "COMPUTE_WH"
  database: "PRESIDENTIAL_ANALYTICS"
  schema: "PUBLIC"
  role: "ACCOUNTADMIN"

# Data Collection Settings
data_collection:
  country: "Senegal"
  country_code: "SN"
  start_year: 1960  # Senegal Independence
  end_year: 2024

# Dashboard Settings
dashboard:
  title: "Senegal Presidential Analytics Dashboard"
  subtitle: "60+ Years of Democratic Progress"
  port: 8501
  theme: "light"

